<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme (Light Mode) -->
    <style name="Base.Theme.Thryft" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Brand Colors -->
        <item name="colorPrimary">@color/deep_plum</item>
        <item name="colorPrimaryVariant">@color/midnight</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

        <!-- Secondary Brand Colors -->
        <item name="colorSecondary">@color/sage</item>
        <item name="colorSecondaryVariant">@color/steel</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background Colors -->
        <item name="android:colorBackground">@color/cloud</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Error Colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Text Appearance -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>
    </style>

    <style name="Theme.Thryft" parent="Base.Theme.Thryft" />

    <style name="Theme.Thryft.Splash" parent="Theme.Thryft">
        <!-- Make system splash instant/invisible -->
        <item name="android:windowBackground">@color/cloud</item>
        <item name="windowSplashScreenBackground">@color/cloud</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.Thryft.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/deep_plum</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>

    <style name="Widget.Thryft.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- TextInputLayout Styles -->
    <style name="Widget.Thryft.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>
        <item name="boxBackgroundColor">@color/surface_muted</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.Thryft.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Switch/Toggle Styles -->
    <style name="Widget.Thryft.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="thumbTint">@color/white</item>
        <item name="trackTint">@color/deep_plum</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="Widget.Thryft.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/steel</item>
        <item name="itemTextColor">@color/steel</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Thryft.BottomNavigationView.ActiveIndicator</item>
        <item name="android:background">@color/surface</item>
    </style>

    <style name="Widget.Thryft.BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/deep_plum</item>
    </style>
</resources>
