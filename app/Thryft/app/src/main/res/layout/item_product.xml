<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/margin_sm"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/corner_radius_lg"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_sm">

        <!-- Product Image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_product_image"
            android:layout_width="0dp"
            android:layout_height="140dp"
            app:cardBackgroundColor="@color/surface_muted"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_product_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/product_image"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/backgrounds/scenic" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Favorite/Wishlist Icon -->
        <ImageView
            android:id="@+id/iv_favorite"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="@dimen/margin_sm"
            android:background="@drawable/bg_favorite"
            android:clickable="true"
            android:contentDescription="@string/add_to_wishlist"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_favorite"
            app:layout_constraintEnd_toEndOf="@id/cv_product_image"
            app:layout_constraintTop_toTopOf="@id/cv_product_image"
            app:tint="@color/text_secondary" />

        <!-- Availability Badge -->
        <TextView
            android:id="@+id/tv_availability"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_sm"
            android:background="@drawable/bg_badge_available"
            android:paddingHorizontal="@dimen/padding_sm"
            android:paddingVertical="4dp"
            android:text="@string/available"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_xs"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/cv_product_image"
            app:layout_constraintStart_toStartOf="@id/cv_product_image" />

        <!-- Product Name -->
        <TextView
            android:id="@+id/tv_product_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_sm"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="@string/product_name"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_md"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cv_product_image"
            tools:text="Vintage Denim Jacket" />

        <!-- Product Category -->
        <TextView
            android:id="@+id/tv_product_category"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/category"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_xs"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_product_name"
            tools:text="Jackets" />

        <!-- Product Price -->
        <TextView
            android:id="@+id/tv_product_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_sm"
            android:layout_marginBottom="@dimen/margin_xs"
            android:text="@string/price"
            android:textColor="@color/deep_plum"
            android:textSize="@dimen/text_size_lg"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_product_category"
            tools:text="Rs. 4,500" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>