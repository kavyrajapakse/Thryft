<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/margin_xs"
    android:layout_marginHorizontal="@dimen/margin_sm"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/corner_radius_lg"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_md">

        <!-- Product Image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_product_image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardBackgroundColor="@color/surface_muted"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_product_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/product_image"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/backgrounds/scenic" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Product Details -->
        <LinearLayout
            android:id="@+id/ll_product_details"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_md"
            android:layout_marginEnd="@dimen/margin_sm"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/cv_product_image"
            app:layout_constraintEnd_toStartOf="@id/iv_remove"
            app:layout_constraintStart_toEndOf="@id/cv_product_image"
            app:layout_constraintTop_toTopOf="@id/cv_product_image">

            <!-- Product Name -->
            <TextView
                android:id="@+id/tv_product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_md"
                android:textStyle="bold"
                tools:text="Vintage Denim Jacket" />

            <!-- Size & Color -->
            <TextView
                android:id="@+id/tv_size_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_xs"
                tools:text="Size: M • Color: Blue" />

            <TextView
                android:id="@+id/tv_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_xs"
                tools:text="Color: Blue" />

            <!-- Price -->
            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_sm"
                android:textColor="@color/deep_plum"
                android:textSize="@dimen/text_size_lg"
                android:textStyle="bold"
                tools:text="Rs. 4,500" />

        </LinearLayout>

        <!-- Remove Button -->
        <ImageView
            android:id="@+id/iv_remove"
            android:layout_width="@dimen/icon_size_md"
            android:layout_height="@dimen/icon_size_md"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/remove_from_cart"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/ic_delete"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/error" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>