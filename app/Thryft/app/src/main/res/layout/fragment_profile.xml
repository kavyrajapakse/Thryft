<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cloud"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/padding_lg">

        <!-- Profile Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_md"
            app:cardBackgroundColor="@color/deep_plum"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/padding_xl">

                <!-- Profile Picture -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/white"
                    app:strokeWidth="3dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Profile Picture -->
                        <ImageView
                            android:id="@+id/iv_profile_picture"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/profile_picture"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_person_placeholder" />

                        <!-- Camera Icon -->
                        <ImageView
                            android:id="@+id/iv_edit_profile_picture"
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:layout_gravity="bottom|end"
                            android:background="@drawable/bg_edit_profile"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="6dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/white" />

                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- User Name -->
                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_md"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_heading"
                    android:textStyle="bold"
                    tools:text="John Doe" />

                <!-- User Email -->
                <TextView
                    android:id="@+id/tv_user_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_xs"
                    android:textColor="@color/white"
                    android:alpha="0.9"
                    android:textSize="@dimen/text_size_sm"
                    tools:text="john.doe@email.com" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Profile Information Card (Expandable) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_md"
            android:layout_marginTop="@dimen/margin_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header (Clickable) -->
                <LinearLayout
                    android:id="@+id/ll_personal_info_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_md">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_person"
                        app:tint="@color/deep_plum" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_md"
                        android:layout_weight="1"
                        android:text="@string/personal_information"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <!-- Expand/Collapse Arrow -->
                    <ImageView
                        android:id="@+id/iv_personal_info_arrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/text_disabled" />

                </LinearLayout>

                <!-- Expandable Content -->
                <LinearLayout
                    android:id="@+id/ll_personal_info_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_md"
                    android:visibility="gone">

                    <!-- Full Name Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_full_name"
                        style="@style/Widget.Thryft.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/full_name"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_full_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email Input (Read-only) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_email"
                        style="@style/Widget.Thryft.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:hint="@string/email"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:enabled="false"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone Number Input -->
<!--                    <com.google.android.material.textfield.TextInputLayout-->
<!--                        android:id="@+id/til_phone"-->
<!--                        style="@style/Widget.Thryft.TextInputLayout"-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_marginTop="@dimen/margin_sm"-->
<!--                        android:hint="@string/phone_number"-->
<!--                        app:prefixText="+94 "-->
<!--                        app:startIconDrawable="@drawable/ic_phone"-->
<!--                        app:startIconTint="@color/text_secondary">-->

<!--                        <com.google.android.material.textfield.TextInputEditText-->
<!--                            android:id="@+id/et_phone"-->
<!--                            android:layout_width="match_parent"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:inputType="phone"-->
<!--                            android:maxLength="9"-->
<!--                            android:textColor="@color/text_primary"-->
<!--                            android:textSize="@dimen/text_size_md" />-->

<!--                    </com.google.android.material.textfield.TextInputLayout>-->

                    <!-- Save Changes Button -->
                    <Button
                        android:id="@+id/btn_save_changes"
                        style="@style/Widget.Thryft.Button"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="@dimen/margin_md"
                        android:text="@string/save_changes"
                        android:textSize="@dimen/text_size_md" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Saved Addresses (Expandable) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_md"
            android:layout_marginTop="@dimen/margin_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header (Clickable) -->
                <LinearLayout
                    android:id="@+id/ll_addresses_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_md">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_location"
                        app:tint="@color/deep_plum" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_md"
                        android:layout_weight="1"
                        android:text="@string/saved_addresses"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <!-- Expand/Collapse Arrow -->
                    <ImageView
                        android:id="@+id/iv_addresses_arrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/text_disabled" />

                </LinearLayout>

                <!-- Expandable Content -->
                <LinearLayout
                    android:id="@+id/ll_addresses_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_md"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_saved_addresses"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_sm" />

                    <!-- Add Address Button -->
                    <Button
                        android:id="@+id/btn_add_address"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:text="@string/add_address"
                        android:textAllCaps="false"
                        android:textColor="@color/deep_plum"
                        app:cornerRadius="@dimen/corner_radius_md"
                        app:strokeColor="@color/deep_plum"
                        app:strokeWidth="1dp" />

                    <!-- RecyclerView for addresses (when available) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_addresses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- General Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_md"
            android:layout_marginTop="@dimen/margin_sm"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_sm">

                <!-- Section Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_sm"
                    android:layout_marginTop="@dimen/margin_xs"
                    android:layout_marginBottom="@dimen/margin_sm"
                    android:text="@string/general"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_xs"
                    android:textStyle="bold" />

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/ll_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_md">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/deep_plum" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_md"
                        android:layout_weight="1"
                        android:text="@string/settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_disabled" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="@dimen/margin_md"
                    android:background="@color/border" />

                <!-- Contact Us -->
                <LinearLayout
                    android:id="@+id/ll_contact_us"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_md">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_contact"
                        app:tint="@color/deep_plum" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_md"
                        android:layout_weight="1"
                        android:text="@string/contact_us"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_disabled" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="@dimen/margin_md"
                    android:background="@color/border" />

                <!-- Store Location -->
                <LinearLayout
                    android:id="@+id/ll_store_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_md">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_map"
                        app:tint="@color/deep_plum" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_md"
                        android:layout_weight="1"
                        android:text="@string/store_location"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_disabled" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="@dimen/margin_md"
                    android:background="@color/border" />

                <!-- About -->
                <LinearLayout
                    android:id="@+id/ll_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/padding_md">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/deep_plum" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_md"
                        android:layout_weight="1"
                        android:text="@string/about"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_disabled" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_md"
            android:paddingVertical="@dimen/padding_md"
            android:text="@string/logout"
            android:textAllCaps="false"
            android:textColor="@color/error"
            android:textSize="@dimen/text_size_md"
            app:cornerRadius="@dimen/corner_radius_md"
            app:icon="@drawable/ic_logout"
            app:iconGravity="textStart"
            app:iconTint="@color/error"
            app:strokeColor="@color/error"
            app:strokeWidth="1dp" />

        <!-- App Version -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/margin_sm"
            android:layout_marginBottom="@dimen/margin_md"
            android:text="@string/app_version"
            android:textColor="@color/text_disabled"
            android:textSize="@dimen/text_size_xs" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>