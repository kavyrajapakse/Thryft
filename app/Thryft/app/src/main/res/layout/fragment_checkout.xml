<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cloud">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="2dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/checkout"
            app:titleTextColor="@color/text_primary" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Delivery Address Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin_md"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_md">

                    <!-- Section Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/deep_plum" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_sm"
                            android:layout_weight="1"
                            android:text="@string/delivery_address"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_xl"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Full Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_full_name"
                        style="@style/Widget.Thryft.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_md"
                        android:hint="@string/til_full_name"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_full_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone Number -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_phone"
                        style="@style/Widget.Thryft.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:hint="@string/phone_number"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/text_secondary"
                        app:prefixText="+94 ">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:maxLength="9"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_email"
                        style="@style/Widget.Thryft.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_md"
                        android:hint="@string/til_email"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Address Line 1 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_address_line1"
                        style="@style/Widget.Thryft.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:hint="@string/address_line1"
                        app:startIconDrawable="@drawable/ic_home"
                        app:startIconTint="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_address_line1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Address Line 2 (Optional) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_address_line2"
                        style="@style/Widget.Thryft.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:hint="@string/address_line2">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_address_line2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- City and Postal Code Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:orientation="horizontal">

                        <!-- City -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_city"
                            style="@style/Widget.Thryft.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/margin_sm"
                            android:layout_weight="1"
                            android:hint="@string/city">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_city"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_md" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Postal Code -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_postal_code"
                            style="@style/Widget.Thryft.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_sm"
                            android:layout_weight="1"
                            android:hint="@string/postal_code">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_postal_code"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="5"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_md" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Province/State -->
<!--                    <com.google.android.material.textfield.TextInputLayout-->
<!--                        android:id="@+id/til_province"-->
<!--                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_marginTop="@dimen/margin_sm"-->
<!--                        android:hint="@string/province"-->
<!--                        app:boxBackgroundColor="@color/surface_muted"-->
<!--                        app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"-->
<!--                        app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"-->
<!--                        app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"-->
<!--                        app:boxCornerRadiusTopStart="@dimen/corner_radius_md"-->
<!--                        app:boxStrokeColor="@color/deep_plum">-->

<!--                        <AutoCompleteTextView-->
<!--                            android:id="@+id/acv_province"-->
<!--                            android:layout_width="match_parent"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:inputType="none"-->
<!--                            android:textColor="@color/text_primary"-->
<!--                            android:textSize="@dimen/text_size_md" />-->

<!--                    </com.google.android.material.textfield.TextInputLayout>-->

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Order Summary Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_md"
                android:layout_marginTop="@dimen/margin_sm"
                android:layout_marginBottom="@dimen/margin_md"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/corner_radius_lg"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_md">

                    <!-- Section Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_receipt"
                            app:tint="@color/deep_plum" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_sm"
                            android:layout_weight="1"
                            android:text="@string/order_summary"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_xl"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Items Count -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_md"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/items"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_md" />

                        <TextView
                            android:id="@+id/tv_items_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md"
                            tools:text="3 items" />

                    </LinearLayout>

                    <!-- Subtotal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/subtotal"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_md" />

                        <TextView
                            android:id="@+id/tv_subtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md"
                            tools:text="Rs. 8,500" />

                    </LinearLayout>

                    <!-- Delivery Fee -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/delivery_fee"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_md" />

                        <TextView
                            android:id="@+id/tv_delivery_fee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md"
                            tools:text="Rs. 300" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/margin_md"
                        android:background="@color/border" />

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/total"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_xl"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/deep_plum"
                            android:textSize="@dimen/text_size_xl"
                            android:textStyle="bold"
                            tools:text="Rs. 8,800" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Place Order Button (Fixed at Bottom) -->
    <Button
        android:id="@+id/btn_place_order"
        style="@style/Widget.Thryft.Button"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_large"
        android:layout_gravity="bottom"
        android:layout_margin="@dimen/margin_md"
        android:text="@string/place_order"
        android:textSize="@dimen/text_size_lg" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>