<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cloud"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner Section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cv_banner"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_margin="@dimen/margin_md"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="2dp">

            <ImageView
                android:id="@+id/iv_banner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/banner"
                android:scaleType="centerCrop"
                android:src="@drawable/dress" /> <!-- your drawable -->

        </com.google.android.material.card.MaterialCardView>

        <!-- Categories Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_md"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_md"
            android:paddingEnd="@dimen/padding_md">

            <!-- Categories Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/categories"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_xl"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_see_all_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/padding_sm"
                    android:text="@string/see_all"
                    android:textColor="@color/deep_plum"
                    android:textSize="@dimen/text_size_sm"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Categories RecyclerView (Horizontal) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_sm"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="5"
                tools:listitem="@layout/item_category" />

        </LinearLayout>

        <!-- New Arrivals Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_lg"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_md"
            android:paddingEnd="@dimen/padding_md"
            android:paddingBottom="@dimen/padding_lg">

            <!-- New Arrivals Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/new_arrivals"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_xl"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_see_all_products"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/padding_sm"
                    android:text="@string/see_all"
                    android:textColor="@color/deep_plum"
                    android:textSize="@dimen/text_size_sm"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- New Arrivals RecyclerView (Horizontal) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_new_arrivals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_sm"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="6"
                tools:listitem="@layout/item_product" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>