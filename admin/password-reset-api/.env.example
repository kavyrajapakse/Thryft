PORT=4000
APP_BASE_URL=http://127.0.0.1:5500
RESET_TOKEN_TTL_MINUTES=20

# Allowed CORS origins (comma separated). Add your live admin URL later.
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,null

# Firebase Admin service account values
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-client-email
# Keep escaped newlines as \n in this value
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# SECURITY: keep this false in normal usage.
# Set true only for local testing if SMTP is not configured.
ALLOW_INSECURE_TERMINAL_RESET_LINK_LOG=false

# SMTP config for sending reset links by email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Admin Security <no-reply@example.com>"
